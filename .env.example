# ============================================================
# DevSphere Academy — Environment Variables
# Copy this file to .env and fill in real values
# ============================================================

# Database
DB_USER=devsphere
DB_PASSWORD=your_secure_password_here
DB_NAME=devsphere_db
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://devsphere:your_secure_password_here@postgres:5432/devsphere_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secrets — generate with: openssl rand -hex 64
JWT_SECRET=devsphere_jwt_secret
JWT_REFRESH_SECRET=devsphere_refresh_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Judge0 Code Execution API
# Get your key at: https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your_rapidapi_key_here
JUDGE0_HOST=judge0-ce.p.rapidapi.com

# App URLs
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Email (for password reset, optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@devsphere.academy

# Admin
ADMIN_EMAIL=admin@devsphere.academy
ADMIN_PASSWORD=change_immediately

# Node
NODE_ENV=development
PORT=4000
